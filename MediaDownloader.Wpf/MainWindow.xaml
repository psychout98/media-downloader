<Window x:Class="MediaDownloader.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaDownloader.Wpf.ViewModels"
        xmlns:conv="clr-namespace:MediaDownloader.Wpf.Converters"
        Title="Media Downloader" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header / Tab bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <TextBlock Text="Media Downloader" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <RadioButton Content="Dashboard" GroupName="Tabs" IsChecked="True"
                                 Style="{StaticResource {x:Type ToggleButton}}"
                                 Checked="DashboardTab_Checked" Margin="0,0,4,0" />
                    <RadioButton Content="Settings" GroupName="Tabs"
                                 Style="{StaticResource {x:Type ToggleButton}}"
                                 Checked="SettingsTab_Checked" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab content -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}" Background="Transparent" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Dashboard Tab -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                    <StackPanel Margin="24">

                        <!-- Server Status Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Margin="0,0,12,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource RedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusDotColor}" Value="Green">
                                                        <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusDotColor}" Value="Orange">
                                                        <Setter Property="Fill" Value="{StaticResource OrangeBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ServerStatus}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ServerSubtitle}" Style="{StaticResource DimText}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Start" Style="{StaticResource AccentButton}" Command="{Binding StartServerCommand}"
                                            Visibility="{Binding IsServerRunning, Converter={StaticResource InverseBoolToVis}}" />
                                    <Button Content="Stop" Style="{StaticResource Surface2Button}" Command="{Binding StopServerCommand}"
                                            Visibility="{Binding IsServerRunning, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Info Grid (shown when running) -->
                        <UniformGrid Columns="4" Margin="0,0,0,16" Visibility="{Binding IsServerRunning, Converter={StaticResource BoolToVis}}">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding ActiveJobCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Active Jobs" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LibraryCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BlueBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Library Items" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding MpcStatus}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                    <TextBlock Text="MPC-BE" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DiskFree}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                    <TextBlock Text="Disk Free" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Active Downloads -->
                        <TextBlock Text="Active Downloads" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Visibility="{Binding IsServerRunning, Converter={StaticResource BoolToVis}}" />
                        <ItemsControl ItemsSource="{Binding ActiveDownloads}" Margin="0,0,0,16"
                                      Visibility="{Binding IsServerRunning, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <DockPanel Grid.Row="0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" DockPanel.Dock="Left" />
                                                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                            </DockPanel>
                                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                                <Border Background="{StaticResource Surface3Brush}" CornerRadius="3" Height="6" />
                                                <Border Background="{StaticResource AccentBrush}" CornerRadius="3" Height="6" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding>
                                                            <MultiBinding.Converter>
                                                                <conv:BoolToVisibilityConverter />
                                                            </MultiBinding.Converter>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                            <TextBlock Grid.Row="1" Text="{Binding SizeText}" Style="{StaticResource DimText}" Margin="0,14,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Quick Actions -->
                        <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <UniformGrid Columns="4" Margin="0,0,0,16">
                            <Button Style="{StaticResource AccentButton}" Command="{Binding OpenWebUiCommand}" Margin="0,0,8,0" Padding="16,16">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" />
                                    <TextBlock Text="Open Web UI" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Margin="4,0" Padding="16,16" Command="{Binding OpenMediaLibraryCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Setter Property="Background" Value="{StaticResource BlueBrush}" />
                                    </Style>
                                </Button.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📁" FontSize="20" HorizontalAlignment="Center" />
                                    <TextBlock Text="Media Library" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Margin="4,0" Padding="16,16" Command="{Binding LaunchMpcCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Setter Property="Background" Value="{StaticResource GreenBrush}" />
                                    </Style>
                                </Button.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="▶" FontSize="20" HorizontalAlignment="Center" />
                                    <TextBlock Text="Launch MPC-BE" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Margin="8,0,0,0" Padding="16,16" Command="{Binding RefreshLibraryCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Setter Property="Background" Value="{StaticResource OrangeBrush}" />
                                    </Style>
                                </Button.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔄" FontSize="20" HorizontalAlignment="Center" />
                                    <TextBlock Text="Refresh Library" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <!-- Update Card -->
                        <Border Margin="0,0,0,16" Padding="16" CornerRadius="8"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
                                    <GradientStop Color="#a855f7" Offset="1" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>2</Thickness>
                            </Border.BorderThickness>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock Text="⬆ Update Available" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource DimText}" Margin="0,4,0,0">
                                        <Run Text="{Binding CurrentVersion}" />
                                        <Run Text=" → " />
                                        <Run Text="{Binding LatestVersion}" Foreground="{StaticResource AccentBrush}" />
                                    </TextBlock>
                                </StackPanel>
                                <Button Content="Update Now" Style="{StaticResource AccentButton}" Command="{Binding UpdateNowCommand}"
                                        DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <!-- Stopped empty state -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="32"
                                Visibility="{Binding IsServerRunning, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Server is not running" FontSize="16" Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="Start the server to see dashboard information" Style="{StaticResource DimText}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">

                        <!-- Directories -->
                        <TextBlock Text="Directories" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Movies Directory" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding MoviesDir, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,4,0,12"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />

                                <TextBlock Text="TV Shows Directory" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding TvDir, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,4,0,12"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />

                                <TextBlock Text="Archive Directory" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding ArchiveDir, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,4,0,12"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />

                                <TextBlock Text="App Data Directory" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding AppDataDir, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,4,0,0"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />
                            </StackPanel>
                        </Border>

                        <!-- API Keys -->
                        <TextBlock Text="API Keys" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="TMDB API Key" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding TmdbApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />

                                <TextBlock Text="Real-Debrid API Key" Style="{StaticResource DimText}" />
                                <DockPanel Margin="0,4,0,0">
                                    <Button Content="Test" Style="{StaticResource Surface2Button}" DockPanel.Dock="Right" Margin="8,0,0,0" Command="{Binding TestRdKeyCommand}" />
                                    <TextBlock Text="{Binding RdKeyStatus}" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0"
                                               FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}" />
                                    <TextBox Text="{Binding RdApiKey, UpdateSourceTrigger=PropertyChanged}"
                                             Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Behavior -->
                        <TextBlock Text="Behavior" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Content="Start on Windows boot" IsChecked="{Binding StartOnBoot}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                <CheckBox Content="Auto-start server" IsChecked="{Binding AutoStartServer}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                <CheckBox Content="Auto-update (applies updates automatically)" IsChecked="{Binding AutoUpdate}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                                <TextBlock Text="Max Concurrent Downloads" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding MaxDownloads, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="0,4,0,12"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />

                                <TextBlock Text="Watch Threshold" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding WatchThreshold, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />
                            </StackPanel>
                        </Border>

                        <!-- MPC-BE -->
                        <TextBlock Text="MPC-BE" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="URL" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding MpcUrl, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,4,0,12"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />

                                <TextBlock Text="Executable Path" Style="{StaticResource DimText}" />
                                <TextBox Text="{Binding MpcExePath, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,4,0,0"
                                         Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6" />
                            </StackPanel>
                        </Border>

                        <!-- Save/Cancel -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Style="{StaticResource Surface2Button}" Command="{Binding CancelSettingsCommand}" Margin="0,0,8,0" />
                            <Button Content="Save Settings" Style="{StaticResource AccentButton}" Command="{Binding SaveSettingsCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,8">
            <DockPanel>
                <TextBlock Text="{Binding CurrentVersion}" Style="{StaticResource DimText}" DockPanel.Dock="Left" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
